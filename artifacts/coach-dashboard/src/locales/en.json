  "privacy": {
    "app_name": "ADAPT System",
    "title": "Privacy Policy",
    "last_updated": "Last updated: March 27, 2026",
    "section_1_title": "1. Overview",
    "section_1_body": "ADAPT System is a personalized fitness coaching application. It is reserved for athletes monitored by their coach. This policy describes what data is collected, how it is used and protected.",
    "section_2_title": "2. Collected data",
    "section_2_intro": "As part of the coaching, the application collects the following data:",
    "section_2_li_1": "Identification information: first name, last name, email address",
    "section_2_li_2": "Health and fitness data: recovery scores (sleep, energy, stress, soreness, motivation), RPE (perceived effort level), training data",
    "section_2_li_3": "Nutritional data: scanned and consumed foods (if the nutrition feature is used)",
    "section_2_li_4": "Usage data: session history, progress, training statistics",
    "section_2_li_5": "Communications: messages exchanged with the coach via the integrated messaging",
    "section_3_title": "3. Use of data",
    "section_3_intro": "The collected data is used exclusively to:",
    "section_3_li_1": "Adapt training programs to the athlete's physical and mental state",
    "section_3_li_2": "Allow the coach to track the athlete's progress",
    "section_3_li_3": "Generate personal performance statistics",
    "section_3_li_4": "Facilitate communication between athlete and coach",
    "section_3_outro": "No data is sold, shared or transmitted to third parties for commercial or advertising purposes.",
    "section_4_title": "4. Storage and security",
    "section_4_body": "Data is securely stored on servers hosted by Replit Inc. (United States). Communications are encrypted via TLS/HTTPS. Passwords are hashed with bcrypt and never stored in clear text. Access to data is protected by JWT authentication.",
    "section_5_title": "5. Access and control of your data",
    "section_5_body": "You can at any time request access, rectification or deletion of your personal data by contacting the coach directly via the application messaging or by email. In accordance with GDPR, you have the right of access, rectification, erasure and portability of your data.",
    "section_6_title": "6. Health data",
    "section_6_body": "Daily check-in data (sleep, energy, stress, etc.) are considered well-being data. They are not shared with third parties and are used only as part of coaching. The application does not collect medical data in the legal sense of the term.",
    "section_7_title": "7. Required permissions",
    "section_7_li_camera_label": "Camera",
    "section_7_li_camera_body": ": used only to scan food barcodes in the nutrition section. No image is saved or transmitted.",
    "section_7_li_notif_label": "Notifications",
    "section_7_li_notif_body": ": used to send session reminders and coach messages.",
    "section_7_li_net_label": "Network access",
    "section_7_li_net_body": ": required to synchronize data with the server.",
    "section_8_title": "8. Data retention",
    "section_8_body": "Data is kept for the entire duration of the coaching follow-up. If the follow-up stops, the data can be deleted on request. Data is automatically deleted when the account is closed.",
    "section_9_title": "9. Contact",
    "section_9_body": "For any question regarding your personal data or this privacy policy, you can contact:",
    "section_9_contact_name": "Loïc Mehdi Houmy Jaumotte",
    "section_9_contact_channel": "Via the in-app messaging or via the coach dashboard.",
    "footer": "© 2026 ADAPT System. All rights reserved."
  },
